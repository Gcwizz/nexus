# Secrets not provided by nix devShell
# Service config (DATABASE_URL, NEO4J_*, REDIS_URL, BETTER_AUTH_*, etc.)
# is exported by flake.nix — do not duplicate here.

# Claude API
ANTHROPIC_API_KEY=sk-ant-xxx

# S3 (Cloudflare R2 — optional, only needed for file storage features)
S3_ACCESS_KEY=
S3_SECRET_KEY=
